# LLM API配置
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_MAX_TOKENS=4096

# 嵌入模型配置（Graphiti local 模式需要，优先使用 EMBEDDING_API_KEY）
# 可选：若使用与 LLM 相同的嵌入服务，可留空，默认使用 LLM_API_KEY
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=5

# 知识图谱配置 - local模式
KNOWLEDGE_GRAPH_MODE=local

# Neo4j 配置
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# OASIS 模拟配置
OASIS_DEFAULT_MAX_ROUNDS=10

# Report Agent 配置
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
